{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "./dist",
    "types": ["node", "jest"],
    "exactOptionalPropertyTypes": false,
    "declaration": false,
    "declarationMap": false,
    "paths": {
      "@casageri/shared-types": ["../../packages/shared-types/src"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist", "src/__tests__"]
}
