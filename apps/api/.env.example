NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:3000

# Supabase — copie do painel em Project Settings > API
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Database — Project Settings > Database > Connection string (URI)
# Troque [YOUR-PASSWORD] pela senha do banco
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.xxxxxxxxxxx.supabase.co:5432/postgres

# JWT — gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=cole_aqui_string_aleatoria_32chars_minimo
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=cole_aqui_outra_string_aleatoria_32chars
JWT_REFRESH_EXPIRES_IN=30d

# Redis local (via Docker)
REDIS_URL=redis://localhost:6379

# Twilio (opcional — deixe vazio para pular SMS/WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=

# SMTP (opcional — deixe vazio para pular emails)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Storage
STORAGE_BUCKET_DOCUMENTS=documents
STORAGE_BUCKET_PHOTOS=photos
