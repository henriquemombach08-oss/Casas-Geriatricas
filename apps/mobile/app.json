{
  "expo": {
    "name": "CasaGeri",
    "slug": "casageri",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "casageri",
    "userInterfaceStyle": "light",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#2563EB",
          "defaultChannel": "default"
        }
      ]
    ],
    "android": {
      "adaptiveIcon": { "backgroundColor": "#2563EB" },
      "package": "com.casageri.app",
      "googleServicesFile": "./google-services.json"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.casageri.app",
      "buildNumber": "1"
    },
    "experiments": { "typedRoutes": true },
    "extra": {
      "eas": { "projectId": "casageri-prod" }
    }
  }
}
