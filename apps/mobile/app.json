{
  "expo": {
    "name": "CasaGeri",
    "slug": "casageri",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "casageri",
    "userInterfaceStyle": "light",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "expo-navigation-bar"
    ],
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#92400E"
      },
      "package": "com.casageri.app",
      "statusBar": {
        "backgroundColor": "#00000000",
        "translucent": true,
        "style": "dark"
      },
      "softwareKeyboardLayoutMode": "pan"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.casageri.app",
      "buildNumber": "1"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "44c2891c-2e2e-4822-afda-6b1b87324e62"
      }
    },
    "owner": "henriquesilva008"
  }
}
